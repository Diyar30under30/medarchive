# ── MedArchive configuration ───────────────────────────────────────────────
# Two-profile runtime. Copy to .env and adjust. Defaults below = local SQLite
# dev mode that runs WITHOUT Docker. docker-compose.yml overrides these for the
# brief-compliant Postgres+pgvector path.

# Database. SQLite (host dev, no install) OR Postgres (Docker / production).
#   SQLite:   sqlite:///./medarchive.db
#   Postgres: postgresql+psycopg://medarchive:medarchive@db:5432/medarchive
DATABASE_URL=sqlite:///./medarchive.db

# Feature flags — degrade gracefully when a dependency is absent on the host.
ENABLE_EMBEDDINGS=false        # true requires sentence-transformers (+torch)
ENABLE_OCR=false               # true requires system tesseract-ocr + lang data

# Pipeline behavior on startup.
AUTO_LOAD_REFERENCE=true       # load data/reference into the directory on boot
AUTO_SEED_FIXTURES=false       # generate + ingest sample_archive.zip on boot

# Matching engine (tunable — see normalization/matcher.py).
MATCH_FUSION_LEXICAL=0.45
MATCH_FUSION_SEMANTIC=0.55
MATCH_THRESHOLD_AUTO=0.85
MATCH_THRESHOLD_REVIEW=0.65
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Paths.
REFERENCE_DIR=../data/reference
INCOMING_DIR=../data/incoming
RAW_STORE_DIR=../data/raw_store

# CORS for the frontend dev server.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
